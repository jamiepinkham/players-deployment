# Unified Environment Variables for BMPL Stack
# Copy this file to .env and fill in actual values
# NEVER commit the actual .env file!

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# Cloudflare Tunnel Token
# Get this from Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# =============================================================================
# PRODUCTION - Players Rails App
# =============================================================================

# PostgreSQL Database
POSTGRES_PASSWORD=CHANGE_ME

# Rails
SECRET_KEY_BASE=CHANGE_ME

# Mailgun SMTP
MAILGUN_SMTP_USERNAME=postmaster@mail.billymartinplayersleague.com
MAILGUN_SMTP_PASSWORD=CHANGE_ME

# =============================================================================
# QA - Players Rails App (Testing)
# =============================================================================

# Git Reference for QA deployments (branch/tag/SHA)
# Examples: jp-consolidated-fa-improvements, main, sha-9332ec2b...
GIT_REF=main

# QA Database (optional - uses production values if not set)
DATABASE_NAME_QA=players_qa
POSTGRES_PASSWORD_QA=

# QA Rails (optional - uses production SECRET_KEY_BASE if not set)
SECRET_KEY_BASE_QA=

# =============================================================================
# GHOST BLOG
# =============================================================================

# Ghost MySQL Database
GHOST_DB_PASSWORD=CHANGE_ME

# Ghost Mail (Mailgun SMTP)
GHOST_MAIL_USER=postmaster@mail.billymartinplayersleague.com
GHOST_MAIL_PASSWORD=CHANGE_ME
GHOST_MAIL_FROM=postmaster@mail.billymartinplayersleague.com
