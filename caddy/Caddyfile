# Caddyfile for Cloudflare Tunnel
# Explicitly set proxy headers for Ghost

# Rails app (Production)
http://players.billymartinplayersleague.com {
    reverse_proxy players-web:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto https
        header_up Host {host}
    }
}

# Rails app (Integration)
http://players-integration.billymartinplayersleague.com {
    reverse_proxy players-web-integration:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto https
        header_up Host {host}
    }
}

# Ghost blog
http://billymartinplayersleague.com {
    reverse_proxy ghost:2368 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto https
        header_up Host {host}
    }
}
